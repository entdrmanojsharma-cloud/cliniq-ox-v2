  estimateNumber  String         @map("estimate_number") @db.VarChar(100)
  patientName     String         @map("patient_name") @db.VarChar(150)
  codeApplied     String         @map("code_applied") @db.VarChar(50)
  discountAmount  Decimal        @map("discount_amount") @db.Decimal(10, 2)
  appliedByUserId String         @map("applied_by_user_id") @db.Uuid
  appliedByName   String         @map("applied_by_name") @db.VarChar(255)
  doctorId        String?        @map("doctor_id") @db.Uuid
  doctorName      String?        @map("doctor_name") @db.VarChar(255)
  appliedAt       DateTime       @default(now()) @map("applied_at") @db.Timestamptz

  hospital        HospitalProfile @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  estimate        Estimate        @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  appliedByUser   User            @relation(fields: [appliedByUserId], references: [id], onDelete: Restrict)

  @@map("discount_code_audit_logs")
}

model AdminDiscountCodeEditLog {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hospitalId      String         @map("hospital_id") @db.Uuid
  codeId          String         @map("code_id") @db.Uuid
  codeName        String         @map("code_name") @db.VarChar(50)
  oldValue        Json           @map("old_value")
  newValue        Json           @map("new_value")
  editedByUserId  String         @map("edited_by_user_id") @db.Uuid
  editedByName    String         @map("edited_by_name") @db.VarChar(255)
  reason          String         @map("reason") @db.Text
  editedAt        DateTime       @default(now()) @map("edited_at") @db.Timestamptz

  hospital        HospitalProfile @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  code            DiscountCode    @relation(fields: [codeId], references: [id], onDelete: Cascade)
  editedByUser    User            @relation(fields: [editedByUserId], references: [id], onDelete: Restrict)

  @@map("admin_discount_code_edit_logs")
}

model DiscountCodeAccessRequest {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hospitalId      String         @map("hospital_id") @db.Uuid
  requestedByUserId String       @map("requested_by_user_id") @db.Uuid
  requestedByName String         @map("requested_by_name") @db.VarChar(255)
  status          String         @default("PENDING") @db.VarChar(50) // PENDING, APPROVED, REJECTED
  approvedByUserId String?       @map("approved_by_user_id") @db.Uuid
  approvedByName  String?        @map("approved_by_name") @db.VarChar(255)
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  hospital        HospitalProfile @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  requestedByUser User            @relation("RequestedByUser", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  approvedByUser  User?           @relation("ApprovedByUser", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@map("discount_code_access_requests")
}

model DiagnosisMaster {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hospitalId      String   @map("hospital_id") @db.Uuid
  diagnosisCode   String   @map("diagnosis_code") @db.VarChar(50)
  diagnosisName   String   @map("diagnosis_name") @db.VarChar(255)
  description     String?  @db.Text
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz
  deletedBy       String?  @map("deleted_by") @db.Uuid

  hospital        HospitalProfile      @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  deleter         User?                @relation("DeletedByDiagnosis", fields: [deletedBy], references: [id], onDelete: SetNull)
  procedures      DiagnosisProcedure[]

  @@unique([hospitalId, diagnosisCode])
  @@map("diagnosis_master")
}

model DiagnosisProcedure {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  diagnosisId     String   @map("diagnosis_id") @db.Uuid
  surgeryId       String   @map("surgery_id") @db.Uuid
  isDefault       Boolean  @default(false) @map("is_default")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  diagnosis       DiagnosisMaster @relation(fields: [diagnosisId], references: [id], onDelete: Cascade)
  surgery         SurgeryMaster   @relation(fields: [surgeryId], references: [id], onDelete: Cascade)

  @@unique([diagnosisId, surgeryId])
  @@map("diagnosis_procedures")
}


model Notification {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hospitalId String   @map("hospital_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  title      String   @db.VarChar(100)
  message    String   @db.Text
  type       String   @db.VarChar(50) // e.g., "ESTIMATE_PENDING", "EVENT_CONFLICT"
  linkId     String?  @map("link_id") @db.Uuid // Target entity ID
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  hospital   HospitalProfile @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
